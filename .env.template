# ═══════════════════════════════════════════════════════════════
# Kalshi Trading Bot — Environment Configuration
# Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════

# ── Kalshi API ─────────────────────────────────────────────────
# Generate at: https://kalshi.com/account/api-keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=/opt/kalshi-trader/kalshi-key.pem

# Set to "true" for demo environment (RECOMMENDED for testing)
KALSHI_USE_DEMO=false

# ── Local LLM (LM Studio on Mac Mini) ─────────────────────────
# Update IP if your Mac Mini's wired IP changes
LLM_ENDPOINT=http://192.168.1.238:1234/v1
LLM_MODEL=qwen3.5-9b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Claude API (optional arbiter) ──────────────────────────────
# Only used when USE_CLAUDE_ARBITER=true
# Saves money by using local LLM for most decisions
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
USE_CLAUDE_ARBITER=false

# ── Trading Parameters ─────────────────────────────────────────
# Max dollars per single trade
MAX_BET_AMOUNT=5.00

# Stop trading if daily losses exceed this dollar amount
MAX_DAILY_LOSS=10.00

# Max simultaneous open positions
MAX_OPEN_POSITIONS=3

# Kelly criterion fraction (0.25 = quarter-Kelly, conservative)
KELLY_FRACTION=0.25

# Minimum edge (model_prob - market_prob) to trigger a trade
# 0.08 = 8% edge required. Higher = fewer but higher-conviction trades
MIN_EDGE=0.08

# Market categories to scan (comma-separated)
# Options: climate, economics, financials, politics
CATEGORIES=climate,economics,financials

# Seconds between scan cycles (300 = 5 minutes)
SCAN_INTERVAL=300

# Circuit breaker: stop trading if daily loss exceeds this % of balance
CIRCUIT_BREAKER_PCT=0.15

# ── System ─────────────────────────────────────────────────────
DB_PATH=/opt/kalshi-trader/trade_journal.db
LOG_LEVEL=INFO
