# ═══════════════════════════════════════════════════════════════
# ktrader — Configuration
# Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════

# ── Kalshi API ─────────────────────────────────────────────────
# Generate at: https://kalshi.com/account/api-keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi-key.pem

# Set to "true" for demo environment (recommended for testing)
KALSHI_USE_DEMO=false

# ── Trading Parameters ─────────────────────────────────────────
# IMPORTANT: Bot starts in dry-run mode. Set to false for live trading.
DRY_RUN=true

MAX_BET_AMOUNT=1.00
MAX_DAILY_LOSS=5.00
MAX_OPEN_POSITIONS=5
KELLY_FRACTION=0.25
MIN_EDGE=0.10
SCAN_INTERVAL=600
CIRCUIT_BREAKER_PCT=0.10

# Market categories to scan (comma-separated)
# Options: climate, economics, financials, politics, science
CATEGORIES=economics,financials,politics,science,climate

# ── Local LLM (LM Studio) ─────────────────────────────────────
# Point to your LM Studio instance running Qwen or similar
# Leave blank if not using a local model
LLM_ENDPOINT=
LLM_ENDPOINT_FALLBACK=
LLM_MODEL=qwen2.5-14b-instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Cloud LLM APIs ─────────────────────────────────────────────
# Multi-model consensus uses all available APIs
# Leave blank to skip that model
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
XAI_API_KEY=
OPENAI_API_KEY=

# Analysis mode
USE_DUAL_ANALYSIS=true
USE_SINGLE_AGENT=true

# ── Data Enrichment APIs ───────────────────────────────────────
# FRED (Federal Reserve data) — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# OpenWeatherMap — free tier at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Sports Arbitrage ───────────────────────────────────────────
SPORTS_ENABLED=true
SPORTS_SCAN_INTERVAL=30

# ── Collective Intelligence ────────────────────────────────────
# Join the collective: share anonymized predictions, get crowd signals
# Apply for membership at https://ktrader.dev/collective
COLLECTIVE_ENABLED=false
COLLECTIVE_SERVER=https://ktrader.dev/collective
COLLECTIVE_API_KEY=

# ── Dashboard ──────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5100

# ── System ─────────────────────────────────────────────────────
DB_PATH=trade_journal.db
LOG_LEVEL=INFO
